{
  "mcpServers": {
    "dart": {
      "command": "dart",
      "args": ["mcp-server"]
    },
    "patrol": {
      "command": "./.claude/run-patrol",
      "env": {
        "PROJECT_ROOT": "./example/pokebattle_rest",
        "PATROL_FLAGS": "",
        "SHOW_TERMINAL": "false"
      }
    },
    "serverpod": {
      "command": "serverpod_mcp",
      "args": []
    },
    "testeador": {
      "command": "dart",
      "args": ["run", "--no-serve-devtools", "testeador:testeador", "mcp"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TESTEADOR_PROJECT_ROOT": "${workspaceFolder}",
        "TESTEADOR_MCP_ENABLE_MULTIDEV": "1"
      }
    }
  }
}
